# Optional override. The default is the small LLMLingua-2 BERT checkpoint.
COMPRESSOR_MODEL=microsoft/llmlingua-2-bert-base-multilingual-cased-meetingbank

# Keep at least this fraction of tokens even when aggressiveness is 1.0.
COMPRESSOR_MIN_RATE=0.45

# Use cpu for the default Docker deployment. Set to cuda only with a CUDA PyTorch image.
COMPRESSOR_DEVICE=cpu
